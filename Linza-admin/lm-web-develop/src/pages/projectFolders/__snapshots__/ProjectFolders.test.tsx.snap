                </span>
              </button>
              <span
                class="yc-text-input yc-text-input_view_normal yc-text-input_size_m yc-text-input_pin_round-round g-pagination-input g-pagination-input_size_m g-pagination__input"
              >
                <span
                  class="yc-text-input__content"
                >
                  <input
                    class="yc-text-input__control yc-text-input__control_type_input"
                    placeholder="Page #"
                    value=""
                  />
                </span>
              </span>
              <div
                class="g-select g-pagination__page-sizer"
              >
                <div
                  class="g-select-control g-select-control_size_m g-select-control_pin_round-round g-select-control_has-value"
                  role="group"
                >
                  <button
                    aria-controls="select-popup-g-:r6:"
                    aria-expanded="false"
                    aria-haspopup="listbox"
                    class="g-select-control__button g-select-control__button_size_m g-select-control__button_view_normal g-select-control__button_pin_round-round"
                    role="combobox"
                    type="button"
                  >
                    <span
                      class="g-select-control__option-text"
                    >
                      10
                    </span>
                  </button>
                  <svg
                    aria-hidden="true"
                    class="yc-icon g-select-control__chevron-icon"
                    fill="currentColor"
                    height="16"
                    stroke="none"
                    width="16"
                    xmlns="http://www.w3.org/2000/svg"
                    xmlns:xlink="http://www.w3.org/1999/xlink"
                  >
                    <svg
                      fill="none"
                      viewBox="0 0 16 16"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        clip-rule="evenodd"
                        d="M2.97 5.47a.75.75 0 0 1 1.06 0L8 9.44l3.97-3.97a.75.75 0 1 1 1.06 1.06l-4.5 4.5a.75.75 0 0 1-1.06 0l-4.5-4.5a.75.75 0 0 1 0-1.06Z"
                        fill="currentColor"
                        fill-rule="evenodd"
                      />
                    </svg>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
`;
