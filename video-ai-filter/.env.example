# Docker Compose: порт на хосте (внутри контейнера всегда 8000). Если «port already allocated» — 8080 и т.д.
# HOST_PORT=8000

# Режим: openrouter (облако) | vllm (свой сервер, см. https://docs.vllm.ai/en/stable/serving/openai_compatible_server.html )
# INFERENCE_BACKEND=openrouter

OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=qwen/qwen3-vl-8b-thinking

# --- vLLM (когда INFERENCE_BACKEND=vllm): base URL до /v1, модель как в `vllm serve --model ...`
# INFERENCE_BACKEND=vllm
# VLLM_BASE_URL=http://127.0.0.1:8001/v1
# VLLM_API_KEY=EMPTY
# VLLM_MODEL=Qwen/Qwen2-VL-7B-Instruct

# UPLOAD_DIR=./data/uploads
# DB_PATH=./data/jobs.db

# Optional: only paths under this directory are accepted by POST /jobs/from-path
# ALLOWED_IMPORT_DIR=/data/videos

# 0 = no limit (large uploads need proxy timeouts)
# MAX_UPLOAD_BYTES=0

# По умолчанию промпт уже включает полную классификацию Linza (K1–K7, id k1_1 … k7_4, матрица).
# Задайте DEFAULT_PROMPT только если нужен свой текст целиком.
# DEFAULT_PROMPT=...
# Аналогично для модерации речи (verdict = id Linza или none):
# DEFAULT_TRANSCRIPT_MODERATION_PROMPT=...

# Одновременные запросы к vision LLM (1–32), по умолчанию 8
# VISION_PARALLEL_WORKERS=8

# Interlaced / кривой decode для OpenCV: auto (ffprobe tt/tb/bt/bb → перекод) | always | never
# VIDEO_FFMPEG_NORMALIZE=auto
# VIDEO_NORMALIZE_CRF=23

# Транскрипция (faster-whisper) + модерация речи тем же LLM, после анализа кадров
# AUDIO_TRANSCRIPTION_ENABLED=true
# FFMPEG_PATH=ffmpeg
# WHISPER_MODEL_SIZE=tiny
# WHISPER_DEVICE=auto
# WHISPER_COMPUTE_TYPE=auto
# MAX_TRANSCRIPT_CHARS_FOR_LLM=24000
