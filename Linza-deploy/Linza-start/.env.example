# Auth
AUTH_SECRET_KEY=linza-secret-change-in-production
AUTH_ADMIN_LOGIN=admin
AUTH_ADMIN_PASSWORD=admin

# S3 Storage (Timeweb Cloud)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=https://s3.twcstorage.ru
S3_BUCKET_NAME=5aca33a6-7dff-49cb-8069-3442ccb455c3
S3_REGION=ru-1

# DNS для контейнеров (Google/Яндекс API из storage-service и linza-board). При Errno -3 в Docker задайте свои резолверы.
# DOCKER_DNS_PRIMARY=8.8.8.8
# DOCKER_DNS_SECONDARY=1.1.1.1

# Analytics
DATABASE_PATH=/app/data/linza.db

# Линза.Детектор — очередь анализа на «Источниках» (board вызывает POST /api/jobs и опрашивает статус)
# В Docker значения из этого файла попадают в контейнер только через docker-compose.yml (сервис linza-board → environment).
# После правок .env выполните: docker compose up -d --force-recreate linza-board
# DETECTOR_API_BASE_URL=http://linza-detect.sociallab.ru:38080
# Публичный URL входа в Linza (как с браузера, но без пути) — детектор запросит GET …/api/detector-fetch/…
# Тот же смысл можно задать как LINZA_PUBLIC_URL. localhost с удалённого детектора не откроется — нужен домен, IP в интернете или туннель (ngrok).
# DETECTOR_PUBLIC_FETCH_BASE_URL=https://your-linza.example.com
# LINZA_PUBLIC_URL=https://your-linza.example.com
# Подпись одноразовых ссылок (можно не задавать, если задан AUTH_SECRET_KEY):
# DETECTOR_FETCH_SECRET=
# Опционально: customerId в теле задачи, профиль PREVIEW/FULL, интервал опроса (сек):
# DETECTOR_CUSTOMER_ID=
# DETECTOR_PROFILE=FULL
# DETECTOR_POLL_INTERVAL_SEC=5
# DETECTOR_POLL_TIMEOUT_SEC=14400
# Своё дерево detectionClasses (JSON-массив), иначе — полный набор подклассов по умолчанию:
# DETECTOR_DETECTION_CLASSES_JSON=


# PostgreSQL (linza-board)
POSTGRES_USER=linza
POSTGRES_PASSWORD=linza
POSTGRES_DB=linza_board
# Порт Postgres на хосте (внутри Docker сети всегда 5432). Если 5432 занят — оставьте по умолчанию 5433.
# POSTGRES_PUBLISH_PORT=5433

# Credential encryption (linza-board)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Inter-service auth
SERVICE_API_KEY=linza-internal-key-change-in-production

# Cloud PostgreSQL backup (optional)
# Uncomment and set to enable periodic backup to external/cloud PostgreSQL.
# Connection string: postgresql://user:password@cloud-host:5432/linza
# CLOUD_DATABASE_URL=postgresql://linza:password@cloud-pg.example.com:5432/linza_board
# BACKUP_INTERVAL=6h

# MinIO (local S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Яндекс OAuth (только для контейнера linza-board / локальный uvicorn из linza-board/)
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
# Точно как Redirect URI в https://oauth.yandex.ru/ (с http/https)
YANDEX_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/yandex/callback
# Google OAuth (консоль Google Cloud — Redirect URI должен совпадать)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback
# Необязательно: область доступа (по умолчанию только чтение Диска)
# GOOGLE_OAUTH_SCOPE=https://www.googleapis.com/auth/drive.readonly
# Куда редирект после Яндекса, если не удастся взять origin из браузера (Docker без Vite: http://localhost:8000)
FRONTEND_BASE_URL=http://localhost:5173

# SSL/TLS (optional — for HTTPS mode)
# SSL_CERT_PATH=./ssl/cert.pem
# SSL_KEY_PATH=./ssl/key.pem
# NGINX_CONF=./nginx/nginx-ssl.conf
