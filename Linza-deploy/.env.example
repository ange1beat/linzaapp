# Скопируйте в .env и заполните. Не коммитьте .env с секретами.
# Важно: строки не обрывать (в редакторе без переноса по середине URL/ключа).

# --- База (PostgreSQL) ---
POSTGRES_USER=linza
POSTGRES_PASSWORD=linza
POSTGRES_DB=linza_board
POSTGRES_PUBLISH_PORT=5433

# CORS: перечислите все origin, с которых открывается фронт (IP/домен nginx/board без пути).
# Пример прод: 
CORS_ORIGINS=http://72.56.242.139,http://localhost:5173,http://localhost:3000,http://localhost

AUTH_SECRET_KEY=change-me
AUTH_ADMIN_LOGIN=admin
AUTH_ADMIN_PASSWORD=admin
VIDEO_FFMPEG_NORMALIZE=auto

# Шифрование паролей доступа в board (Fernet, 32 байта base64)
CREDENTIAL_ENCRYPTION_KEY=

# Один ключ для межсервисных запросов (storage, analytics, …)
SERVICE_API_KEY=

# --- S3 ---
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=https://s3.twcstorage.ru
S3_BUCKET_NAME=
S3_REGION=ru-1

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- OAuth (полные строки; redirect = тот же хост, что у пользователей в браузере) ---
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
# Пример: http://ВАШ_IP/api/integrations/yandex/callback
YANDEX_OAUTH_REDIRECT_URI=
# Куда редирект после логина (часто совпадает с первым origin в CORS_ORIGINS)
FRONTEND_BASE_URL=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# --- ИИ-анализ: video-ai-filter (по умолчанию) ---
DETECTOR_PROVIDER=video_ai_filter
# Ключ пишется в .env в корне Linza-deploy — compose подставляет в контейнер video-ai-filter:
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001
VIDEO_AI_INFERENCE_BACKEND=openrouter
# Параллельные HTTP-запросы к vision LLM (кадры-сэмплы) в video-ai-filter
VISION_PARALLEL_WORKERS=8
# Чересстрочное видео → перекод перед OpenCV: auto | always | never
VIDEO_FFMPEG_NORMALIZE=auto

# --- Легаси: внешний Линза.Детектор (если DETECTOR_PROVIDER=legacy) ---
DETECTOR_API_BASE_URL=
DETECTOR_PUBLIC_FETCH_BASE_URL=
LINZA_PUBLIC_URL=
DETECTOR_FETCH_SECRET=
DETECTOR_FETCH_TOKEN_TTL_SEC=7200
